# AI 配置示例
# 复制此文件为 .env 并填写您的配置

# AI API 密钥（必需）
AI_API_KEY=your_api_key_here

# AI 模型（可选，默认 deepseek-chat）
AI_MODEL=deepseek-chat

# 服务商（可选：deepseek/openrouter/siliconflow）
AI_PROVIDER=deepseek

# DeepSeek 自定义 Base URL（可选，用于第三方服务）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 最大 Token 数（可选，默认 2048）
# AI_MAX_TOKENS=2048
